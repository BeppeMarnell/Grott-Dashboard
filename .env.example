# Copy to .env and adjust. These are read by the app / docker-compose.
# Nothing here is secret — they're deployment settings for YOUR setup.

# --- data & timezone ---
# SQLite db path (Docker uses /data/solar.db on a mounted volume).
SOLAR_DB=data/solar.db
# Local timezone used to stamp readings and attribute days.
SOLAR_TZ=Europe/Rome

# --- dashboard ---
SOLAR_WEB_HOST=127.0.0.1
SOLAR_WEB_PORT=8088
# Feed-in tariff (currency/kWh) used to value production.
SOLAR_PRICE=0.124
# Dashboard auto-refresh interval (seconds).
SOLAR_REFRESH=60

# --- datalogger admin (only used by scripts/logger_config.py) ---
# Your ShineLanBox/ShineLink datalogger's LAN IP and admin UI credentials.
LOGGER_HOST=192.168.1.226
LOGGER_USER=admin
LOGGER_PASS=admin

# --- grott setup (only used by scripts/setup-grott.sh) ---
# Upstream grott source and pinned commit this project was built against.
GROTT_REPO=https://github.com/johanmeijer/grott.git
GROTT_COMMIT=fb52e2d4ff3065f60db45a7c2c82f2ad7e9f8463
