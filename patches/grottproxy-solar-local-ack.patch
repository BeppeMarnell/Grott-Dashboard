+# --- solar_panels_logger patch: local ACK helpers ---------------------------
+# Some Growatt loggers (e.g. an unregistered ShineLanBox) consider themselves
+# "offline" and only send keepalive pings, buffering real data, until a SERVER
+# acknowledges their data records. In plain proxy mode grott relies on the cloud
+# for that ACK; if the cloud stays silent the logger never streams data. These
+# helpers let the proxy send the same ACK the Growatt server would, so the
+# logger goes online and flushes its data to us. Pure-python CRC (no libscrc).
+def _crc16_modbus(data: bytes) -> int:
+    crc = 0xFFFF
+    for b in data:
+        crc ^= b
+        for _ in range(8):
+            crc = (crc >> 1) ^ 0xA001 if (crc & 1) else (crc >> 1)
+    return crc
+
+def build_local_ack(data: bytes) -> bytes:
+    header = data[0:8].hex()
+    protocol = header[6:8]
+    rectype = header[12:16]
+    if protocol == "02":
+        return bytes.fromhex(header[0:8] + "0003" + rectype + "00")
+    headerackx = bytes.fromhex(header[0:8] + "0003" + rectype + "47")
+    return headerackx + _crc16_modbus(headerackx).to_bytes(2, "big")
+# --- end patch --------------------------------------------------------------
+
