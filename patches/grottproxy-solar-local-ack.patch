+            elif rectype in ("16", "19"):
+                # Ping/keepalive. Echo it straight back to the logger, locally and
+                # independently of the cloud forward connection. A Growatt logger
+                # reverts to "offline" (and stops streaming data) if its pings go
+                # unanswered -- which happens whenever the cloud socket flaps or the
+                # inverter sleeps overnight. Always answering the ping ourselves keeps
+                # the logger "online", so it auto-resumes data each morning with no
+                # power-cycle. The data records it then sends are ACKed above.
+                try:
