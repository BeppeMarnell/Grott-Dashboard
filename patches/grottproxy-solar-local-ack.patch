+
+        # solar_panels_logger patch: if this came from the logger and is a data/
+        # announce record, send a local server-style ACK so an "offline" logger
+        # goes online and streams its data (does not affect cloud forwarding).
+        if self.s in self.clientsocks:
+            rectype = header[14:16]
+            if rectype in ("03", "04", "50", "1b", "20"):
